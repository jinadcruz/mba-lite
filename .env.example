# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mba_lite:mba_lite_dev@localhost:5432/mba_lite

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── AI / LLM ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                    # fallback tutor (optional)

# ─── Payments ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# ─── Storage ─────────────────────────────────────────────────────────────────
S3_BUCKET=mba-lite-content
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
CDN_BASE_URL=https://cdn.mbalite.app

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ─── Web (Next.js) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ─── Mobile (Expo) ───────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─── Search ──────────────────────────────────────────────────────────────────
TYPESENSE_API_KEY=mba_lite_dev_key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108

# ─── Notifications ───────────────────────────────────────────────────────────
FCM_SERVER_KEY=...
