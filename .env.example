# MBA Lite — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mba_lite"
REDIS_URL="redis://localhost:6379"

# ─── Authentication (NextAuth.js) ────────────────────────────
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── AI Providers ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# AI Tutor Config
AI_TUTOR_PRIMARY_MODEL=claude-sonnet-4-20250514
AI_TUTOR_FALLBACK_MODEL=gpt-4o
AI_TUTOR_SIMPLE_MODEL=claude-haiku-4-5-20251001
AI_TUTOR_DAILY_TOKEN_BUDGET=20000

# ─── Payments (Stripe) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxx
STRIPE_ANNUAL_PRICE_ID=price_xxxxx

# ─── AWS / Storage ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=mba-lite-content
CLOUDFRONT_URL=https://cdn.mbalite.app

# ─── Search (Typesense) ─────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=MBA Lite <noreply@mbalite.app>

# ─── Analytics & Monitoring ──────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=

# ─── App Config ──────────────────────────────────────────────
NODE_ENV=development
