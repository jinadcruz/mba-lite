{
  "name": "mba-lite",
  "version": "0.0.1",
  "description": "AI-powered micro-learning MBA tutor — web application",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
