{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@mba-lite/shared/*": ["packages/shared/src/*"],
      "@mba-lite/ai-tutor/*": ["packages/ai-tutor/src/*"],
      "@mba-lite/srs-engine/*": ["packages/srs-engine/src/*"],
      "@mba-lite/ui/*": ["packages/ui/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", "build", ".next", ".expo"]
}
